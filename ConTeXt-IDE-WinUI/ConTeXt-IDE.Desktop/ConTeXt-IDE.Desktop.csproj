  </Compile>
  <Compile Update="Views\PDFWindowViewer.xaml.cs">
	<DependentUpon>PDFWindowViewer.xaml</DependentUpon>
  </Compile>
  <Compile Update="Views\SelectFolder.xaml.cs">
	<DependentUpon>SelectFolder.xaml</DependentUpon>
  </Compile>
  <Compile Update="Views\SelectNew.xaml.cs">
	<DependentUpon>SelectNew.xaml</DependentUpon>
  </Compile>
  <Compile Update="Views\SelectTemplate.xaml.cs">
	<DependentUpon>SelectTemplate.xaml</DependentUpon>
  </Compile>
 </ItemGroup>

 <ItemGroup>
  <Content Update="Assets\GitHub.png">
	<CopyToOutputDirectory>Always</CopyToOutputDirectory>
  </Content>
  <Content Update="Templates\markdown\pictures\NyquistPlot1.png">
	<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
  </Content>
  <Content Update="Templates\projthes\pictures\NyquistPlot1.png">
	<CopyToOutputDirectory>Always</CopyToOutputDirectory>
  </Content>
 </ItemGroup>

 <ItemGroup>
  <Page Update="IconText.xaml">
	<SubType>Designer</SubType>
  </Page>
  <Page Update="MainWindow.xaml">
	<SubType>Designer</SubType>
  </Page>
  <Page Update="Ribbon.xaml">
	<SubType>Designer</SubType>
  </Page>
 </ItemGroup>


<Project Sdk="Microsoft.NET.Sdk">
 <PropertyGroup>
  <OutputType>WinExe</OutputType>
  <TargetFramework>net10.0-windows10.0.26100.0</TargetFramework>
  <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
  <RootNamespace>ConTeXt_IDE</RootNamespace>
  <ApplicationManifest>app.manifest</ApplicationManifest>
  <Platforms>x86;x64;ARM64</Platforms>
  <RuntimeIdentifiers>win-x86;win-x64;win-arm64</RuntimeIdentifiers>
  <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  <WinUISDKReferences>true</WinUISDKReferences>
  <WindowsAppSDKSelfContained>false</WindowsAppSDKSelfContained>
  <UseWinUI>true</UseWinUI>
  <Nullable>enable</Nullable>
  <ApplicationIcon>Square44x44Logo.ico</ApplicationIcon>
  <!--<UseRidGraph>true</UseRidGraph>-->
 </PropertyGroup>
 <PropertyGroup Condition="'$(Configuration)'=='Debug'">
  <Optimize>False</Optimize>
  <WarningLevel>2</WarningLevel>
  <NoWarn>CS1998;CS4014</NoWarn>
 </PropertyGroup>
 <PropertyGroup Condition="'$(Configuration)'=='Release'">
  <WarningLevel>2</WarningLevel>
  <NoWarn>CS1998;CS4014</NoWarn>
 </PropertyGroup>
 <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x86'">
  <Optimize>False</Optimize>
 </PropertyGroup>
 <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
  <Optimize>False</Optimize>
 </PropertyGroup>
 <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|ARM64'">
  <Optimize>False</Optimize>
 </PropertyGroup>
 <ItemGroup>
  <Page Remove="App.xaml" />
 </ItemGroup>
 <ItemGroup>
  <Content Include="About.md">
	<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
  </Content>
  <Content Include="Square44x44Logo.ico" />
  <Content Include="Templates\cv\env_cv.tex">
	<CopyToOutputDirectory>Always</CopyToOutputDirectory>
  </Content>
  <Content Include="Templates\cv\fa-brands-400.ttf">
	<CopyToOutputDirectory>Always</CopyToOutputDirectory>
  </Content>
  <Content Include="Templates\cv\fa-regular-400.ttf">
	<CopyToOutputDirectory>Always</CopyToOutputDirectory>
  </Content>
  <Content Include="Templates\cv\fa-solid-900.ttf">
	<CopyToOutputDirectory>Always</CopyToOutputDirectory>
  </Content>
  <Content Include="Templates\cv\prd_cv.tex">
	<CopyToOutputDirectory>Always</CopyToOutputDirectory>
  </Content>
  <Content Include="Templates\markdown\components\c_0_frontpart.tex">

<UserControl
    x:Class="ConTeXt_IDE.IconText"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ConTeXt_IDE"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
	<StackPanel Style="{StaticResource HorizontalStack}">
		<FontIcon x:Name="FontIcon"></FontIcon>
		<TextBlock x:Name="TextBlock" VerticalAlignment="Center" Style="{StaticResource BodyTextBlockStyle}"/>
	</StackPanel>
</UserControl>
